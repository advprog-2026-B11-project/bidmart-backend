    {
      "name": "📦 Listings",
      "description": "Listing harus dibuat oleh token akun yang sudah ber-role SELLER atau ADMIN. Register default menghasilkan USER, jadi pastikan {{sellerToken}} berasal dari akun SELLER.",
      "item": [
        {
          "name": "Create Listing (as Seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('listingId', res.id);",
                  "    console.log('✅ listingId tersimpan: ' + res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"title\": \"Laptop Gaming Asus ROG\",\n  \"description\": \"Kondisi sangat baik, baterai masih bagus\",\n  \"imageUrl\": \"https://example.com/laptop.jpg\",\n  \"startingPrice\": 5000000,\n  \"reservePrice\": 8000000,\n  \"endTime\": \"2026-12-01T18:00:00\",\n  \"auctionType\": \"ENGLISH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/listings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"]
            },
            "description": "Pakai sellerToken. endTime harus di masa depan. reservePrice optional."
          }
        },
        {
          "name": "Create Listing (Expire Soon - Test Anti-Sniping)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Set endTime ke 90 detik dari sekarang untuk test anti-sniping",
                  "const now = new Date();",
                  "now.setSeconds(now.getSeconds() + 90);",
                  "pm.variables.set('shortEndTime', now.toISOString().slice(0, 19));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('listingId', res.id);",
                  "    console.log('✅ Listing expire dalam 90 detik: ' + res.id);",
                  "    console.log('⏰ Bid sekarang untuk trigger anti-sniping!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"title\": \"[TEST] Anti-Sniping Item\",\n  \"description\": \"Listing untuk test anti-sniping, expire 90 detik\",\n  \"imageUrl\": \"https://example.com/anti-sniping.jpg\",\n  \"startingPrice\": 100000,\n  \"reservePrice\": 150000,\n  \"endTime\": \"{{shortEndTime}}\",\n  \"auctionType\": \"ENGLISH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/listings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"]
            },
            "description": "Listing yang hampir expire untuk test anti-sniping. endTime auto-set 90 detik dari sekarang via pre-request script."
          }
        },
        {
          "name": "Get All Listings",
          "request": {
