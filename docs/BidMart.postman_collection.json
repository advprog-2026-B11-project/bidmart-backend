                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('userId', res.id);",
                  "    console.log('✅ userId tersimpan: ' + res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
