    {
      "name": "📋 Orders",
      "description": "Order otomatis dibuat saat AuctionWonEvent (buyer menang lelang).",
      "item": [
        {
          "name": "Get My Orders (as Buyer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    if (res.length > 0) {",
                  "        pm.collectionVariables.set('orderId', res[0].id);",
                  "        console.log('📦 Order count: ' + res.length);",
                  "    } else {",
                  "        console.log('📭 Belum ada order. Menangkan lelang dulu!');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/buyer/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "buyer", "{{userId}}"]
            },
            "description": "Semua order user sebagai buyer."
          }
        },
        {
          "name": "Update Tracking Number (Seller)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackingNumber\": \"JNE-1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/tracking",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}", "tracking"]
            },
            "description": "Seller input resi. Status otomatis menjadi SHIPPED."
          }
        },
        {
          "name": "Confirm Delivery (Buyer)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}", "confirm"]
            },
            "description": "Buyer konfirmasi terima barang. Status DELIVERED + dana cair ke seller."
          }
        },
        {
          "name": "Dispute Order (Buyer)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Barang tidak sesuai deskripsi, kondisi buruk\"\n}"
