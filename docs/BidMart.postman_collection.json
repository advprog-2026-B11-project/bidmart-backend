            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 10000000,\n  \"method\": \"BANK\",\n  \"paymentDetails\": {\n    \"bankName\": \"BCA\",\n    \"accountNumber\": \"1234567890\"\n  },\n  \"idempotencyKey\": \"{{$randomUUID}}\"\n}"
            },
            "url": {
