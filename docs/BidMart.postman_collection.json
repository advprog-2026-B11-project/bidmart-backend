          "name": "Get My Balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/balance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "wallet", "balance"]
            },
            "description": "Cek saldo: balanceAvailable (bisa dipakai) + balanceLocked (sedang ditahan bid)."
          }
        },
