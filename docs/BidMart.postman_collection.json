{
  "info": {
    "name": "BidMart API",
    "description": "Koleksi API untuk platform lelang BidMart",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Bidding",
      "item": [
        {
          "name": "Place Bid",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"amount\": 150000,\n  \"proxyBid\": false,\n  \"proxyMaxLimit\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bids",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids"]
            },
            "description": "Tempatkan bid pada sebuah listing. Mengembalikan 201 jika berhasil, 409 jika ada race condition setelah 3x retry."
          }
        },
        {
          "name": "Place Proxy Bid",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"amount\": 100000,\n  \"proxyBid\": true,\n  \"proxyMaxLimit\": 500000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bids",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids"]
            },
            "description": "Tempatkan proxy bid. Dana yang di-hold sesuai proxyMaxLimit."
          }
        },
        {
          "name": "Get Bids By Listing",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bids/listing/{{listingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids", "listing", "{{listingId}}"]
            },
            "description": "Ambil semua bid pada listing tertentu, diurutkan dari terbaru."
          }
        },
        {
          "name": "Get Highest Bid",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bids/listing/{{listingId}}/highest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids", "listing", "{{listingId}}", "highest"]
            },
            "description": "Ambil bid tertinggi pada listing tertentu."
          }
        },
        {
          "name": "Get Minimum Next Bid",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bids/listing/{{listingId}}/minimum-bid",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids", "listing", "{{listingId}}", "minimum-bid"]
            },
            "description": "Ambil nilai minimum bid berikutnya yang diperbolehkan (berdasarkan strategi lelang)."
          }
        },
        {
          "name": "Get My Bids",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bids/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids", "me"]
            },
            "description": "Ambil semua bid milik user yang sedang login."
          }
        }
      ]
    },
    {
      "name": "Listing",
      "item": [
        {
          "name": "Create Listing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"title\": \"Laptop Gaming\",\n  \"description\": \"Laptop gaming kondisi baik\",\n  \"startingPrice\": 5000000,\n  \"reservePrice\": 8000000,\n  \"endTime\": \"2026-05-10T18:00:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/listings",
              "host": ["{{baseUrl}}"],
              "path": ["listings"]
            },
            "description": "Buat listing lelang baru. sellerId diambil dari JWT."
          }
        },
        {
          "name": "Get All Listings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/listings",
              "host": ["{{baseUrl}}"],
              "path": ["listings"]
            },
            "description": "Ambil semua listing yang tersedia."
          }
        },
        {
          "name": "Get Listing By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/listings/{{listingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["listings", "{{listingId}}"]
            },
            "description": "Ambil detail listing berdasarkan ID."
          }
        },
        {
          "name": "Update Listing",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Laptop Gaming Updated\",\n  \"description\": \"Deskripsi diperbarui\",\n  \"startingPrice\": 5000000,\n  \"reservePrice\": 9000000,\n  \"endTime\": \"2026-05-12T18:00:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/listings/{{listingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["listings", "{{listingId}}"]
            },
            "description": "Update listing. Hanya bisa dilakukan saat lelang tidak aktif."
          }
        },
        {
          "name": "Delete Listing",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/listings/{{listingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["listings", "{{listingId}}"]
            },
            "description": "Hapus listing. Hanya bisa dilakukan saat lelang tidak aktif."
          }
        }
      ]
    }
  ]
}
