            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/dispute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}", "dispute"]
            },
            "description": "Buyer ajukan sengketa. Status DISPUTED. Menunggu admin resolve."
          }
        },
        {
          "name": "Resolve Dispute (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refundBuyer\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/resolve-dispute",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}", "resolve-dispute"]
            },
            "description": "⚠️ ADMIN only. true=refund buyer (CANCELLED), false=pay seller (DELIVERED)."
          }
        },
        {
          "name": "Update Order Status (Manual)",
