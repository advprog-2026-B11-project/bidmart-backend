    {
      "name": "🔨 Bidding",
      "description": "Place bid sebagai buyer. Pastikan wallet sudah di-top-up dan listing-nya aktif.",
      "item": [
        {
          "name": "Place Bid",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('bidId', res.id);",
                  "    console.log('✅ Bid berhasil ditempatkan!');",
                  "    pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "} else if (pm.response.code === 409) {",
                  "    console.log('⚠️ Race condition! Coba lagi.');",
                  "} else if (pm.response.code === 422) {",
                  "    console.log('❌ Saldo tidak cukup. Top up dulu!');",
                  "} else if (pm.response.code === 400) {",
                  "    const res = pm.response.json();",
                  "    console.log('❌ Bid ditolak: ' + (res.message || JSON.stringify(res)));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"amount\": 5500000,\n  \"proxyBid\": false,\n  \"proxyMaxLimit\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bids",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids"]
            },
            "description": "Tempatkan bid normal. Amount harus > startingPrice DAN > currentHighestBid.\n\nResponse:\n- 201: Sukses\n- 400: Validasi gagal\n- 404: Listing tidak ada\n- 409: Race condition (FE bisa retry)\n- 422: Saldo kurang"
          }
        },
        {
          "name": "Place Proxy Bid (Auto-bid)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"amount\": 5500000,\n  \"proxyBid\": true,\n  \"proxyMaxLimit\": 9000000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bids",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bids"]
            },
            "description": "Proxy bid: sistem otomatis bid sampai proxyMaxLimit. Dana yang di-hold = proxyMaxLimit, bukan amount."
          }
        },
        {
          "name": "Get Bids by Listing",
          "request": {
